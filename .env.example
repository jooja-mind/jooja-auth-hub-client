# Base URL of jooja-auth-hub
# - local dev: http://127.0.0.1:8787
# - current public: https://jooja-auth.leverton.dev
AUTH_HUB_BASE_URL="http://127.0.0.1:8787"

# Optional: admin API key for /v1/admin/* endpoints.
# Keep it secret; do not commit real values.
AUTH_HUB_ADMIN_API_KEY=""

# --- v2 principal identity (preferred) ---
# Server-issued UUID.
AUTH_HUB_PRINCIPAL_ID=""
# Client secret issued together with the principal id.
AUTH_HUB_CLIENT_SECRET=""
# For real agent deployments, prefer putting these values in a local secret file
# outside git, such as ~/.config/jooja-auth-hub-client/env

# --- legacy bearer-mode token access (optional) ---
# Only needed if you still use the shared bearer token flow.
# Must match TOKEN_BEARER_TOKEN on the hub.
AUTH_HUB_BEARER_TOKEN=""
