# Jooja Quick Auth (JQA)
#
# This file is an EXAMPLE. Do not commit real values.
# Prefer storing credentials in a local, non-git secret file.
# See: docs/AI_AGENTS.md

# --- required for token retrieval ---
JQA_UUID=""
JQA_SECRET=""
JQA_PROVIDER="google"

# --- optional overrides ---
# Default is the public JQA deployment:
#   https://jooja-auth.leverton.dev
# Uncomment to point to a local dev instance instead:
# JQA_BASE_URL="http://127.0.0.1:8787"

# Optional: admin API key for /v1/admin/* endpoints (only for admin commands).
JQA_ADMIN_API_KEY=""

# --- legacy bearer-mode token access (transition only) ---
# JQA_BEARER_TOKEN=""
