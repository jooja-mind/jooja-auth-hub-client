# Base URL of jooja-auth-hub
# - local dev: http://127.0.0.1:8787
# - current public: https://jooja-auth.leverton.dev
AUTH_HUB_BASE_URL="http://127.0.0.1:8787"

# Optional: admin API key for /v1/admin/* endpoints.
# Keep it secret; do not commit real values.
AUTH_HUB_ADMIN_API_KEY=""

# Optional: a default principal (only a convenience for the CLI)
# Examples:
#   telegram:540443
#   telegram-chat:-1001234567890
AUTH_HUB_PRINCIPAL="telegram:540443"

# Bearer token for token retrieval endpoints (/v1/tokens/*).
# Must match TOKEN_BEARER_TOKEN on the hub.
AUTH_HUB_BEARER_TOKEN=""
