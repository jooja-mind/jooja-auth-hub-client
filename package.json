{
  "name": "jooja-quick-auth",
  "version": "0.2.0",
  "type": "module",
  "description": "Jooja Quick Auth (JQA) client library + CLI to obtain short-lived provider access tokens.",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "jqa": "bin/jqa.js",
    "jooja-quick-auth": "bin/jqa.js",
    "jooja-auth-hub-client": "bin/jooja-auth-hub-client.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "oauth",
    "tokens",
    "jooja",
    "auth",
    "cli",
    "jqa"
  ],
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
